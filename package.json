{
  "name": "luminexis",
  "version": "1.0.0",
  "description": "Lightweight user idle detection library with warnings and auto-logout support",
  "main": "./dist/Luminexis.js",
  "types": "./dist/Luminexis.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:rollup": "rollup -c",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build && bun run test",
    "publish:npm": "npm publish",
    "publish:bun": "bun publish"
  },
  "keywords": [
    "idle",
    "inactive",
    "timeout",
    "session",
    "user-activity",
    "afk",
    "idle-detection",
    "auto-logout"
  ],
  "author": "DotJumpDot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotjumpdot/luminexis.git"
  },
  "bugs": {
    "url": "https://github.com/dotjumpdot/luminexis/issues"
  },
  "homepage": "https://github.com/dotjumpdot/luminexis#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.45.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
